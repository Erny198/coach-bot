# ── Обязательные ─────────────────────────────────────────────────────────
TELEGRAM_TOKEN=            # @BotFather
ANTHROPIC_API_KEY=         # console.anthropic.com
HMAC_SECRET=               # любая длинная случайная строка: openssl rand -hex 32
DOMAIN=                    # например coachdojo.app (без https://)

# ── ЮKassa (подставим в самом конце) ───────────────────────────────────────
YK_SHOP_ID=                # ID магазина ЮKassa
YK_SECRET_KEY=             # секретный ключ ЮKassa
YK_RECEIPTS_ENABLED=false  # true, если включены «Чеки от ЮKassa» (54-ФЗ)

# ── Необязательные ─────────────────────────────────────────────────────────
OPENAI_API_KEY=            # только если используешь голосовые
CLAUDE_MODEL=claude-sonnet-4-6
ADMIN_USERNAME=ErnestKh8

# ── Хранилище и мост (дефолты обычно ок) ───────────────────────────────────
DATA_DIR=/var/lib/coach-bot/data
# DATABASE_URL=sqlite+aiosqlite:////var/lib/coach-bot/data/bot.db
RUN_BRIDGE=true
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8080
